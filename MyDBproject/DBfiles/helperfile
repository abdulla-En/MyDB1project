--4 Inactive Students
SELECT S.ST_FIRST_NAME, S.ST_LAST_NAME, P.TITLE
FROM STUDENT S
JOIN ENROLLMENTS E ON S.STUDENT_ID = E.STUDENT_ID
JOIN PROGRAM P ON E.PROGRAM_ID = P.PROGRAM_ID
WHERE E.UNITS_COMPLETED = 0 
AND E.ENROLLED_AT >= DATEADD(month, -1, GETDATE());


--5 Active Programs by Category
